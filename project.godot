; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="NekoDash"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.3", "Mobile")
config/icon="res://icon.svg"

[autoload]

AppSettings="*res://src/core/app_settings.gd"
SaveManager="*res://src/core/save_manager.gd"
SceneManager="*res://src/core/scene_manager.gd"
GridSystem="*res://src/core/grid_system.gd"
InputSystem="*res://src/core/input_system.gd"
SfxManager="*res://src/core/sfx_manager.gd"
MusicManager="*res://src/core/music_manager.gd"
; TODO(jam-submission): Disable PlaytestCapture autoload before submission build.
PlaytestCapture="*res://tools/playtest_capture.gd"

[display]

window/size/viewport_width=540
window/size/viewport_height=960
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
window/handheld/orientation=1

[editor_plugins]

enabled=PackedStringArray("res://addons/gut/plugin.cfg")

[gui]

theme/custom="res://assets/themes/global_ui_theme.tres"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
